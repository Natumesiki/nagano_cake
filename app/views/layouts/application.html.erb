<!DOCTYPE html>
<html>
  <head>
    <title>NaganoCake</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_pack_tag 'application', media: 'all', 'data-turbolinks-track': 'reload' %>
    <#%= stylesheet_link_tag 'application', media: 'all', 'data-turbolinks-track': 'reload' %>
    <%= javascript_pack_tag 'application', 'data-turbolinks-track': 'reload' %>
  </head>

  <body>
    <%= yield %>
    <!DOCTYPE html>
<html>
  <head>
    <title>Bookers2</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
   <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1">

   <!--%= stylesheet_link_tag 'application', media: 'all', 'data-turbolinks-track': 'reload' %>-->
    <%= stylesheet_pack_tag 'application', media: 'all', 'data-turbolinks-track': 'reload' %>
    <%= javascript_pack_tag 'application', 'data-turbolinks-track': 'reload' %>
  </head>

  <body>
  <header>
  <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
    <div class="container">
      <a class="navbar-brand" href="/"><span>管理者ログイン</span></a>
      <button class="navbar-toggler" type="button" data-toggle="collapse" data-target="#navbarNavDropdown" aria-controls="navbarNavDropdown" aria-expanded="false" aria-label="Toggle navigation">
        <span class="navbar-toggler-icon"></span>
      </button>
       <div class="collapse navbar-collapse" id="navbarNavDropdown">
      <ul class="navbar-nav ml-auto">
    <% if admin_signed_in? %>
    <li>
        <%= link_to new_admin_session_path , class: 'nav-link text-light' do %>
        <i class="fas fa-home" aria-hidden="true"></i> 商品一覧
      <%end%>
      </li>

    <li>
      <%= link_to admin_path,class: 'nav-link text-light' do %>
       <i class="fas fa-users" aria-hidden="true" ></i> 
       <%end%>
        </li>

    <li >
    <%= link_to  books_path, class: 'nav-link text-light' do %>
    <i class="fas fa-book-open" aria-hidden="true" ></i> Books
     <%end%>
       </li>

      <li>
        <%= link_to  destroy_admin_session_path, method: :delete,  class: 'nav-link text-light' do %>
       <i class="fas fa-sign-out-alt" aria-hidden="true" ></i> Log out
      <%end%>
      </li>

    <% else %>
      <li>
        <%= link_to  root_path , class: 'nav-link text-light' do %>
        <i class="fas fa-home" aria-hidden="true"></i> Home
      <%end%>
      </li>

      <li>
        <%= link_to  about_path, class: 'nav-link text-light' do %>
       <i class="fas fa-link" aria-hidden="true" ></i> About
      <%end%>
      </li>

      <li>
        <%= link_to new_user_registration_path, class: 'nav-link text-light' do %>
         <i class="fas fa-user-plus"  aria-hidden="true"></i> Sign up
      <%end%>
     </li>
      <li>
        <%= link_to  new_user_session_path,  class: 'nav-link text-light' do %>
        <i class="fas fa-sign-in-alt"></i> Log in
      </li>
       <%end%>
       <% end %>

      </ul>
      </div>
    </div>
  </nav>
</header>


  <main>
    <% flash.each do |key, value| %>
   <%=content_tag(:div, value, class: "flash flash__#{key}") %>
   <%end%>
   <%#= flash[:success]%>

   <%= yield %>

</main>
  <footer>
  <div class="container mt-5">
  	<div class="row">
    	<div class="mx-auto">
    	</div>
    </div>
  </div>
</footer>
  </body>
</html>

  </body>
</html>
